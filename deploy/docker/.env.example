MAGIC_STUDIO_SERVER_HOST=0.0.0.0
MAGIC_STUDIO_SERVER_PORT=4318
MAGIC_STUDIO_SERVER_RUNTIME_MODE=server
MAGIC_STUDIO_SERVER_DATA_ROOT=/var/lib/magic-studio

# Unified user-center server contract.
# builtin-local: keep a local user center inside this Magic Studio deployment.
# sdkwork-cloud-app-api: delegate user-center and auth authority to sdkwork-cloud-app-api.
# external-user-center: delegate user-center and auth authority to a third-party identity platform.
MAGIC_STUDIO_USER_CENTER_MODE=builtin-local
MAGIC_STUDIO_USER_CENTER_PROVIDER_KEY=magic-studio-local
MAGIC_STUDIO_USER_CENTER_APP_ID=magic-studio-v2
MAGIC_STUDIO_USER_CENTER_LOCAL_API_BASE_PATH=/api/app/v1/user-center
MAGIC_STUDIO_USER_CENTER_SQLITE_PATH=/var/lib/magic-studio/user-center.db
MAGIC_STUDIO_USER_CENTER_DATABASE_URL=
MAGIC_STUDIO_USER_CENTER_SCHEMA_NAME=
MAGIC_STUDIO_USER_CENTER_TABLE_PREFIX=ms_uc_
MAGIC_STUDIO_USER_CENTER_APP_API_BASE_URL=
MAGIC_STUDIO_USER_CENTER_EXTERNAL_BASE_URL=
MAGIC_STUDIO_USER_CENTER_SECRET_ID=
MAGIC_STUDIO_USER_CENTER_SHARED_SECRET=
MAGIC_STUDIO_USER_CENTER_AUTHORIZATION_HEADER_NAME=Authorization
MAGIC_STUDIO_USER_CENTER_ACCESS_TOKEN_HEADER_NAME=Access-Token
MAGIC_STUDIO_USER_CENTER_REFRESH_TOKEN_HEADER_NAME=Refresh-Token
MAGIC_STUDIO_USER_CENTER_SESSION_HEADER_NAME=x-sdkwork-user-center-session-id
MAGIC_STUDIO_USER_CENTER_AUTHORIZATION_SCHEME=Bearer
MAGIC_STUDIO_USER_CENTER_ALLOW_AUTHORIZATION_FALLBACK_TO_ACCESS_TOKEN=true
MAGIC_STUDIO_USER_CENTER_HANDSHAKE_FRESHNESS_WINDOW_MS=30000
