# SDKWork Environment Configuration
# Copy this file to .env.local for local development

# ============================================
# Application Environment
# ============================================
# Options: development | test | staging | production
VITE_APP_ENV=development

# ============================================
# API Configuration
# ============================================
# Main API
# Development (shared dev API by default; use .env.development.local for localhost overrides)
VITE_API_BASE_URL=https://api-dev.sdkwork.com
VITE_WS_URL=wss://api-dev.sdkwork.com/ws

# Test
# VITE_API_BASE_URL=https://api-test.sdkwork.com
# VITE_WS_URL=wss://api-test.sdkwork.com/ws

# Staging (uncomment for staging builds)
# VITE_API_BASE_URL=https://staging-api.sdkwork.com
# VITE_WS_URL=wss://staging-api.sdkwork.com/ws

# Production (uncomment for production builds)
# VITE_API_BASE_URL=https://api.sdkwork.com
# VITE_WS_URL=wss://api.sdkwork.com/ws

# IM (Instant Messaging) API
# Development
VITE_IM_API_BASE_URL=https://im-dev-api.sdkwork.com

# Test (uncomment for test builds)
# VITE_IM_API_BASE_URL=https://im-test-api.sdkwork.com

# Staging (uncomment for staging builds)
# VITE_IM_API_BASE_URL=https://staging-im-api.sdkwork.com

# Production (uncomment for production builds)
# VITE_IM_API_BASE_URL=https://im-api.sdkwork.com

# ============================================
# Authentication
# ============================================
# API Key for external services
VITE_API_KEY=

# Access token for SDK authentication (required)
VITE_ACCESS_TOKEN=

# ============================================
# Multi-tenancy
# ============================================
VITE_TENANT_ID=
VITE_ORGANIZATION_ID=

# ============================================
# Platform
# Options: web | tauri | electron | mobile
# ============================================
VITE_PLATFORM=web

# Compatibility fallback keys (for shared SDK bootstrap)
VITE_APP_API_BASE_URL=https://api-dev.sdkwork.com
SDKWORK_API_BASE_URL=https://api-dev.sdkwork.com
SDKWORK_ACCESS_TOKEN=
SDKWORK_TENANT_ID=
SDKWORK_ORGANIZATION_ID=
SDKWORK_PLATFORM=web
SDKWORK_TIMEOUT=30000

# ============================================
# Debug Settings
# ============================================
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# ============================================
# Feature Flags
# ============================================
# Analytics (typically enabled in production)
VITE_FEATURE_ANALYTICS=false

# Push Notifications
VITE_FEATURE_NOTIFICATIONS=true

# WebSocket Support
VITE_FEATURE_WEBSOCKET=true

# Caching (typically enabled in production/staging)
VITE_FEATURE_CACHE=false

# ============================================
# Request Configuration
# ============================================
# Timeout in milliseconds
VITE_TIMEOUT=30000

# ============================================
# AI/ML API Keys (Optional)
# ============================================
# Google Gemini
VITE_GEMINI_API_KEY=

# OpenAI
VITE_OPENAI_API_KEY=

# AWS
VITE_AWS_ACCESS_KEY_ID=
VITE_AWS_SECRET_ACCESS_KEY=
VITE_AWS_REGION=
VITE_AWS_S3_BUCKET=
