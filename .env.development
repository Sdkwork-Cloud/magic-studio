# Development Environment
# Shared development API by default. Put localhost overrides in .env.development.local.

# ============================================
# Application Environment
# ============================================
VITE_APP_ENV=development

# ============================================
# API Configuration
# ============================================
# Main API
VITE_API_BASE_URL=https://api-dev.sdkwork.com
VITE_MAGIC_STUDIO_USER_CENTER_MODE=sdkwork-cloud-app-api
VITE_MAGIC_STUDIO_USER_CENTER_PROVIDER_KEY=magic-studio-app-api
VITE_MAGIC_STUDIO_USER_CENTER_LOCAL_API_BASE_PATH=/api/app/v1/user-center
VITE_APP_API_BASE_URL=https://api-dev.sdkwork.com
SDKWORK_API_BASE_URL=https://api-dev.sdkwork.com
VITE_WS_URL=wss://api-dev.sdkwork.com/ws

# IM (Instant Messaging) API
VITE_IM_API_BASE_URL=https://im-dev-api.sdkwork.com

# ============================================
# Platform
# ============================================
VITE_PLATFORM=web
SDKWORK_PLATFORM=web

# ============================================
# Debug Settings
# ============================================
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# ============================================
# Feature Flags
# ============================================
VITE_FEATURE_ANALYTICS=false
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_WEBSOCKET=true
VITE_FEATURE_CACHE=false

# ============================================
# Deployment access credential (private env only)
# ============================================
SDKWORK_ACCESS_TOKEN=

# ============================================
# Request Configuration
# ============================================
VITE_TIMEOUT=30000
SDKWORK_TIMEOUT=30000
