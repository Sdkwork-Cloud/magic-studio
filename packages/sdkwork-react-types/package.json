{
    "name":  "@sdkwork/react-types",
    "version":  "0.1.0",
    "description":  "Type definitions for SDKWork React applications",
    "type":  "module",
    "main":  "./src/index.ts",
    "module":  "./src/index.ts",
    "types":  "./src/index.ts",
    "exports":  {
                    ".":  {
                              "import":  "./src/index.ts",
                              "types":  "./src/index.ts"
                          }
                },
    "files":  [
                  "dist",
                  "README.md"
              ],
    "scripts":  {
                    "dev":  "vite build --watch",
                    "build":  "vite build",
                    "typecheck":  "tsc --noEmit"
                },
    "devDependencies":  {
                            "@types/react":  "catalog:",
                            "@types/react-dom":  "catalog:",
                            "typescript":  "catalog:",
                            "vite":  "catalog:",
                            "vite-plugin-dts":  "catalog:"
                        },
    "keywords":  [
                     "react",
                     "types",
                     "typescript",
                     "sdkwork"
                 ],
    "author":  "SDKWork",
    "license":  "MIT",
    "private":  true
}
