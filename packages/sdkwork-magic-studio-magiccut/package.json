{
  "name": "@sdkwork/magic-studio-magiccut",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./pages": {
      "import": "./src/pages/index.ts",
      "types": "./src/pages/index.ts"
    },
    "./store": {
      "import": "./src/store/index.ts",
      "types": "./src/store/index.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "node ../../scripts/run-package-vite-build.mjs --watch",
    "build": "node ../../scripts/run-package-typecheck.mjs tsconfig.json && node ../../scripts/run-package-vite-build.mjs",
    "typecheck": "node ../../scripts/run-package-typecheck.mjs tsconfig.json",
    "test": "node ../../scripts/run-package-vitest.mjs",
    "test:watch": "node ../../scripts/run-package-vitest-watch.mjs"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@sdkwork/magic-studio-assets": "workspace:*",
    "@sdkwork/magic-studio-audio": "workspace:*",
    "@sdkwork/magic-studio-commons": "workspace:*",
    "@sdkwork/magic-studio-core": "workspace:*",
    "@sdkwork/magic-studio-fs": "workspace:*",
    "@sdkwork/magic-studio-host-types": "workspace:*",
    "@sdkwork/magic-studio-i18n": "workspace:*",
    "@sdkwork/magic-studio-image": "workspace:*",
    "@sdkwork/magic-studio-music": "workspace:*",
    "@sdkwork/magic-studio-settings": "workspace:*",
    "@sdkwork/magic-studio-server": "workspace:*",
    "@sdkwork/magic-studio-sfx": "workspace:*",
    "@sdkwork/magic-studio-types": "workspace:*",
    "@sdkwork/magic-studio-video": "workspace:*",
    "@sdkwork/magic-studio-voicespeaker": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.2"
  },
  "private": true,
  "description": "AI-powered video editing package for Magic Studio"
}
