{
  "name": "@sdkwork/magic-studio-notes",
  "version": "0.1.0",
  "description": "Notes module for Magic Studio",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./pages": {
      "import": "./src/pages/index.ts",
      "types": "./src/pages/index.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "node ../../scripts/run-package-vite-build.mjs --watch",
    "build": "node ../../scripts/run-package-typecheck.mjs tsconfig.json && node ../../scripts/run-package-vite-build.mjs",
    "typecheck": "node ../../scripts/run-package-typecheck.mjs tsconfig.json",
    "test": "node ../../scripts/run-package-vitest.mjs"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@sdkwork/magic-studio-assets": "workspace:*",
    "@sdkwork/magic-studio-audio": "workspace:*",
    "@sdkwork/magic-studio-auth": "workspace:*",
    "@sdkwork/magic-studio-chat": "workspace:*",
    "@sdkwork/magic-studio-commons": "workspace:*",
    "@sdkwork/magic-studio-core": "workspace:*",
    "@sdkwork/magic-studio-editor": "workspace:*",
    "@sdkwork/magic-studio-fs": "workspace:*",
    "@sdkwork/magic-studio-generation-history": "workspace:*",
    "@sdkwork/magic-studio-i18n": "workspace:*",
    "@sdkwork/magic-studio-image": "workspace:*",
    "@sdkwork/magic-studio-server": "workspace:*",
    "@sdkwork/magic-studio-settings": "workspace:*",
    "@sdkwork/magic-studio-types": "workspace:*",
    "@sdkwork/magic-studio-video": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "notes",
    "editor",
    "magic-studio",
    "sdkwork"
  ],
  "author": "SDKWork",
  "license": "MIT",
  "private": true
}
