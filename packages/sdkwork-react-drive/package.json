    "sdkwork-react-editor": "workspace:*",
    "sdkwork-react-fs": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  },
  "private": true,
  "description": "File management and cloud storage package for SDKWork React applications"
