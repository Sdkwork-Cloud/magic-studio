{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@sdkwork/react-commons": ["../sdkwork-react-commons/src"],
      "@sdkwork/react-core": ["../sdkwork-react-core/src"],
      "@sdkwork/react-assets": ["../sdkwork-react-assets/src"],
      "@sdkwork/react-i18n": ["../sdkwork-react-i18n/src"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
