{
    "name":  "@sdkwork/react-trade",
    "version":  "0.1.0",
    "private":  true,
    "type":  "module",
    "main":  "./src/index.ts",
    "types":  "./src/index.ts",
    "exports":  {
                    ".":  {
                              "types":  "./src/index.ts",
                              "import":  "./src/index.ts"
                          },
                    "./components":  {
                                         "types":  "./dist/components/index.d.ts",
                                         "import":  "./dist/components/index.js"
                                     },
                    "./services":  {
                                       "types":  "./dist/services/index.d.ts",
                                       "import":  "./dist/services/index.js"
                                   },
                    "./entities":  {
                                       "types":  "./dist/entities/index.d.ts",
                                       "import":  "./dist/entities/index.js"
                                   },
                    "./hooks":  {
                                    "types":  "./dist/hooks/index.d.ts",
                                    "import":  "./dist/hooks/index.js"
                                }
                },
    "scripts":  {
                    "dev":  "vite build --watch",
                    "build":  "tsc \u0026\u0026 vite build",
                    "typecheck":  "tsc --noEmit"
                },
    "dependencies":  {
                         "react":  "catalog:",
                         "react-dom":  "catalog:",
                         "lucide-react":  "catalog:",
                         "classnames":  "catalog:",
                         "zustand":  "catalog:",
                         "@sdkwork/react-core":  "workspace:*",
                         "@sdkwork/react-commons":  "workspace:*",
                         "@sdkwork/react-auth":  "workspace:*",
                         "@sdkwork/react-workspace":  "workspace:*",
                         "@sdkwork/react-notifications":  "workspace:*",
                         "@sdkwork/react-vip":  "workspace:*",
                         "@sdkwork/react-i18n":  "workspace:*"
                     },
    "devDependencies":  {
                            "typescript":  "catalog:",
                            "vite":  "catalog:",
                            "@types/react":  "catalog:",
                            "@types/react-dom":  "catalog:"
                        }
}
