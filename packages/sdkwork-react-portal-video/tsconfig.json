{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@sdkwork/react-*": ["../sdkwork-react-*/src/index.ts"],
      "sdkwork-react-*": ["../sdkwork-react-*/src/index.ts"],
      "@sdkwork/app-sdk": ["../../../../spring-ai-plus-app-api/sdkwork-sdk-app/sdkwork-app-sdk-typescript/src/index.ts"],
      "@sdkwork/sdk-common": ["../../../../sdk/sdkwork-sdk-commons/sdkwork-sdk-common-typescript/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../../../spring-ai-plus-app-api/sdkwork-sdk-app/sdkwork-app-sdk-typescript/src/**/*.ts",
    "../../../../sdk/sdkwork-sdk-commons/sdkwork-sdk-common-typescript/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}

