{
  "name": "sdkwork-react-film",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "sdkwork-react-assets": "workspace:*",
    "sdkwork-react-commons": "workspace:*",
    "sdkwork-react-core": "workspace:*",
    "sdkwork-react-image": "workspace:*",
    "sdkwork-react-video": "workspace:*",
    "sdkwork-react-voicespeaker": "workspace:*",
    "sdkwork-react-notes": "workspace:*",
    "sdkwork-react-chat": "workspace:*",
    "sdkwork-react-settings": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  },
  "private": true,
  "description": "Film/video production package for SDKWork React applications"
}
