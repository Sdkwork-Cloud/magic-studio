{
  "name": "sdkwork-react-prompt",
  "version": "1.0.0",
  "description": "Prompt Optimization Module - AI prompt optimization for image and video generation",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite --config vite.app.config.ts",
    "build": "vite build",
    "build:app": "vite build --config vite.app.config.ts",
    "build:types": "tsc --emitDeclarationOnly",
    "preview": "vite preview --config vite.app.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sdkwork-react-core": "workspace:*",
    "sdkwork-react-commons": "workspace:*",
    "sdkwork-react-assets": "workspace:*",
    "sdkwork-react-image": "workspace:*",
    "sdkwork-react-video": "workspace:*",
    "sdkwork-react-chat": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "react",
    "sdkwork",
    "prompt",
    "optimization",
    "ai",
    "image",
    "video"
  ]
}
