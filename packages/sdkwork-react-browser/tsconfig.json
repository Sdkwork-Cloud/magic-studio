{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@sdkwork/react-commons": ["../sdkwork-react-commons/src/index.ts"],
      "@sdkwork/react-core": ["../sdkwork-react-core/src/index.ts"],
      "@sdkwork/react-fs": ["../sdkwork-react-fs/src/index.ts"],
      "@sdkwork/react-assets": ["../sdkwork-react-assets/src/index.ts"],
      "@sdkwork/react-settings": ["../sdkwork-react-settings/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
