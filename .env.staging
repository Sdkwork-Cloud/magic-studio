# Staging Environment
# Pre-production testing environment

# ============================================
# Application Environment
# ============================================
VITE_APP_ENV=staging

# ============================================
# API Configuration
# ============================================
# Main API
VITE_API_BASE_URL=https://staging-api.sdkwork.com
VITE_APP_API_BASE_URL=https://staging-api.sdkwork.com
SDKWORK_API_BASE_URL=https://staging-api.sdkwork.com
VITE_WS_URL=wss://staging-api.sdkwork.com/ws

# IM (Instant Messaging) API
VITE_IM_API_BASE_URL=https://staging-im-api.sdkwork.com

# ============================================
# Platform
# ============================================
VITE_PLATFORM=web
SDKWORK_PLATFORM=web

# ============================================
# Debug Settings
# ============================================
VITE_DEBUG=true
VITE_LOG_LEVEL=info

# ============================================
# Feature Flags
# ============================================
VITE_FEATURE_ANALYTICS=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_WEBSOCKET=true
VITE_FEATURE_CACHE=true

