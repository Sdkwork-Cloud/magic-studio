{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Magic Studio",
  "version": "0.1.0",
  "identifier": "com.sdkwork.magicstudio.desktop",
  "build": {
    "beforeDevCommand": "node scripts/tauri-before-dev.mjs",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:9000",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Magic Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 720,
        "center": true,
        "decorations": false,
        "transparent": false,
        "dragDropEnabled": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http://* https://* data: blob: asset: tauri:;",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "icon": [
      "icons/dev/32x32.png",
      "icons/dev/128x128.png",
      "icons/dev/128x128@2x.png",
      "icons/dev/icon.icns",
      "icons/dev/icon.ico"
    ],
    "active": true,
    "targets": ["nsis"],
    "macOS": {
      "entitlements": "./entitlements.plist"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/dev/icon.ico",
        "headerImage": "assets/nsis-header.bmp",
        "sidebarImage": "assets/nsis-sidebar.bmp"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": ["https://api.sdkwork.com/app/v3/api/app/update/latest?app=magic-studio"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwMDM5Nzg5OUMzOUExMDQKUldRRW9UbWNpWmNEOENYT01CV0lhOXR1UFhpaXJsK1Z3aU9lZnNtNzE0TDROWVMwVW9XQnFOelkK"
    }
  }
}
