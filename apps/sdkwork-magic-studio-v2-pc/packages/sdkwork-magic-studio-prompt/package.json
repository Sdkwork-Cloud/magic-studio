{
  "name": "@sdkwork/magic-studio-prompt",
  "version": "1.0.0",
  "description": "Prompt Optimization Module - AI prompt optimization for image and video generation",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    },
    "./pages": {
      "types": "./src/pages/index.ts",
      "import": "./src/pages/index.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "import": "./src/i18n/index.ts"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "node ../../scripts/run-package-vite-build.mjs --watch",
    "build": "node ../../scripts/run-package-typecheck.mjs tsconfig.json && node ../../scripts/run-package-vite-build.mjs",
    "typecheck": "node ../../scripts/run-package-typecheck.mjs tsconfig.json",
    "typecheck:contract": "node ../../scripts/run-package-typecheck.mjs tsconfig.contract.json",
    "lint": "eslint src"
  },
  "dependencies": {
    "@sdkwork/magic-studio-assets": "workspace:*",
    "@sdkwork/magic-studio-chat": "workspace:*",
    "@sdkwork/magic-studio-commons": "workspace:*",
    "@sdkwork/magic-studio-core": "workspace:*",
    "@sdkwork/magic-studio-image": "workspace:*",
    "@sdkwork/magic-studio-i18n": "workspace:*",
    "@sdkwork/magic-studio-server": "workspace:*",
    "@sdkwork/magic-studio-types": "workspace:*",
    "@sdkwork/magic-studio-video": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "magic-studio",
    "sdkwork",
    "prompt",
    "optimization",
    "ai",
    "image",
    "video"
  ]
}
