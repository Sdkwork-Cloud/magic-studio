{
  "name": "@sdkwork/magic-studio-chatppt",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./pages": {
      "import": "./src/pages/index.ts",
      "types": "./src/pages/index.ts"
    },
    "./store": {
      "import": "./src/store/index.ts",
      "types": "./src/store/index.ts"
    },
    "./panels": {
      "import": "./src/panels/index.ts",
      "types": "./src/panels/index.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "node ../../scripts/run-package-vite-build.mjs --watch",
    "build": "node ../../scripts/run-package-typecheck.mjs tsconfig.json && node ../../scripts/run-package-vite-build.mjs",
    "typecheck": "node ../../scripts/run-package-typecheck.mjs tsconfig.json"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@sdkwork/magic-studio-chat": "workspace:*",
    "@sdkwork/magic-studio-commons": "workspace:*",
    "@sdkwork/magic-studio-core": "workspace:*",
    "@sdkwork/magic-studio-i18n": "workspace:*",
    "@sdkwork/magic-studio-server": "workspace:*",
    "@sdkwork/magic-studio-types": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "private": true,
  "description": "Chat-based PPT generation package for Magic Studio"
}
