{
  "name": "@sdkwork/magic-studio-commons",
  "version": "0.1.0",
  "description": "Common UI components and utilities for Magic Studio",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./ui": {
      "import": "./src/components/ui/index.tsx",
      "types": "./src/components/ui/index.tsx"
    },
    "./components": {
      "import": "./src/components/index.ts",
      "types": "./src/components/index.ts"
    },
    "./utils": {
      "import": "./src/utils/index.ts",
      "types": "./src/utils/index.ts"
    },
    "./utils/serviceAdapter": {
      "import": "./src/utils/serviceAdapter.ts",
      "types": "./src/utils/serviceAdapter.ts"
    },
    "./utils/helpers": {
      "import": "./src/utils/helpers.ts",
      "types": "./src/utils/helpers.ts"
    },
    "./utils/logger": {
      "import": "./src/utils/logger.ts",
      "types": "./src/utils/logger.ts"
    },
    "./utils/assetIdentity": {
      "import": "./src/utils/assetIdentity.ts",
      "types": "./src/utils/assetIdentity.ts"
    },
    "./constants": {
      "import": "./src/constants/index.ts",
      "types": "./src/constants/index.ts"
    },
    "./types": {
      "import": "./src/types.ts",
      "types": "./src/types.ts"
    },
    "./algorithms": {
      "import": "./src/algorithms/index.ts",
      "types": "./src/algorithms/index.ts"
    },
    "./hooks": {
      "import": "./src/hooks/index.ts",
      "types": "./src/hooks/index.ts"
    },
    "./services": {
      "import": "./src/services/index.ts",
      "types": "./src/services/index.ts"
    },
    "./framework": {
      "import": "./src/components/framework/index.ts",
      "types": "./src/components/framework/index.ts"
    },
    "./framework/tokens": {
      "import": "./src/components/framework/tokens.ts",
      "types": "./src/components/framework/tokens.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "node ../../scripts/run-package-vite-build.mjs --watch",
    "build": "node ../../scripts/run-package-typecheck.mjs tsconfig.json && node ../../scripts/run-package-vite-build.mjs",
    "typecheck": "node ../../scripts/run-package-typecheck.mjs tsconfig.json"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "dependencies": {
    "@sdkwork/magic-studio-i18n": "workspace:*",
    "@sdkwork/magic-studio-types": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "keywords": [
    "magic-studio",
    "components",
    "ui",
    "sdkwork",
    "commons"
  ],
  "author": "SDKWork",
  "license": "MIT",
  "private": true
}
