{
  "name": "magic-studio",
  "private": true,
  "version": "0.1.1",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "cross-env MAGIC_STUDIO_VITE_MODE=development node scripts/run-vite-dev.mjs",
    "dev:test": "cross-env MAGIC_STUDIO_VITE_MODE=test node scripts/run-vite-dev.mjs",
    "dev:staging": "cross-env MAGIC_STUDIO_VITE_MODE=staging node scripts/run-vite-dev.mjs",
    "dev:prod": "cross-env MAGIC_STUDIO_VITE_MODE=production node scripts/run-vite-dev.mjs",
    "dev:git-sdk": "cross-env MAGIC_STUDIO_SDK_MODE=git MAGIC_STUDIO_VITE_MODE=development node scripts/run-vite-dev.mjs",
    "dev:git-sdk:test": "cross-env MAGIC_STUDIO_SDK_MODE=git MAGIC_STUDIO_VITE_MODE=test node scripts/run-vite-dev.mjs",
    "dev:git-sdk:staging": "cross-env MAGIC_STUDIO_SDK_MODE=git MAGIC_STUDIO_VITE_MODE=staging node scripts/run-vite-dev.mjs",
    "dev:git-sdk:prod": "cross-env MAGIC_STUDIO_SDK_MODE=git MAGIC_STUDIO_VITE_MODE=production node scripts/run-vite-dev.mjs",
    "build": "cross-env MAGIC_STUDIO_VITE_MODE=production node scripts/run-app-build.mjs",
    "build:dev": "cross-env MAGIC_STUDIO_VITE_MODE=development node scripts/run-app-build.mjs",
    "build:test": "cross-env MAGIC_STUDIO_VITE_MODE=test node scripts/run-app-build.mjs",
    "build:staging": "cross-env MAGIC_STUDIO_VITE_MODE=staging node scripts/run-app-build.mjs",
    "build:prod": "cross-env MAGIC_STUDIO_VITE_MODE=production node scripts/run-app-build.mjs",
    "build:git-sdk": "cross-env MAGIC_STUDIO_SDK_MODE=git MAGIC_STUDIO_VITE_MODE=production node scripts/run-app-build.mjs",
    "build:git-sdk:dev": "cross-env MAGIC_STUDIO_SDK_MODE=git MAGIC_STUDIO_VITE_MODE=development node scripts/run-app-build.mjs",
    "build:git-sdk:test": "cross-env MAGIC_STUDIO_SDK_MODE=git MAGIC_STUDIO_VITE_MODE=test node scripts/run-app-build.mjs",
    "build:git-sdk:staging": "cross-env MAGIC_STUDIO_SDK_MODE=git MAGIC_STUDIO_VITE_MODE=staging node scripts/run-app-build.mjs",
    "build:npm-sdk": "pnpm run build:git-sdk",
    "verify:bundle:self-contained": "node scripts/check-desktop-bundle-self-contained.mjs",
    "verify:release:api-target": "node scripts/check-release-api-target.mjs",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "audit:services:policy": "node scripts/validate-service-encapsulation-policy.mjs",
    "audit:services:policy:review-gate": "node scripts/check-service-policy-review-gate.mjs",
    "audit:services": "node scripts/audit-service-encapsulation.mjs --strict",
    "audit:services:report": "node scripts/audit-service-encapsulation.mjs",
    "verify:service-standards": "node scripts/validate-service-encapsulation-policy.mjs && node scripts/audit-service-encapsulation.mjs --strict && pnpm run build:git-sdk",
    "build:packages": "turbo run build --concurrency 100",
    "typecheck": "turbo run typecheck --concurrency 100",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "preview": "vite preview",
    "tauri": "pnpm tauri:dev",
    "tauri:dev": "tauri dev",
    "tauri:build": "cross-env MAGIC_STUDIO_SDK_MODE=git tauri build --no-bundle --config src-tauri/tauri.prod.conf.json",
    "tauri:bundle": "cross-env MAGIC_STUDIO_SDK_MODE=git tauri build --config src-tauri/tauri.prod.conf.json",
    "cdn:download": "node scripts/cdn-download.mjs",
    "zip": "node scripts/zip-project.js",
    "zip:code": "node scripts/zip-project.js --code --report",
    "zip:report": "node scripts/zip-project.js --report",
    "zip:tgz": "node scripts/zip-project.js --format=tgz",
    "check:sdk-standard": "node ../scripts/check-sdk-compliance.mjs --strict && node ../scripts/check-auth-standard.mjs && node ../scripts/check-user-center-standard.mjs && node ../scripts/check-vip-standard.mjs && node ../scripts/check-contacts-standard.mjs && node ../scripts/check-product-standard.mjs && node ../scripts/check-drive-standard.mjs && node ../scripts/check-notification-standard.mjs && node ../scripts/check-trade-standard.mjs",
    "check:sdk-standard:quick": "node ../scripts/check-auth-standard.mjs && node ../scripts/check-user-center-standard.mjs && node ../scripts/check-vip-standard.mjs && node ../scripts/check-contacts-standard.mjs && node ../scripts/check-product-standard.mjs && node ../scripts/check-drive-standard.mjs && node ../scripts/check-notification-standard.mjs && node ../scripts/check-trade-standard.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
