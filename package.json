    "@tiptap/extension-image": "catalog:",
    "@tiptap/extension-link": "catalog:",
    "@tiptap/extension-mention": "catalog:",
    "@tiptap/extension-placeholder": "catalog:",
    "@tiptap/extension-task-item": "catalog:",
    "@tiptap/extension-task-list": "catalog:",
    "@tiptap/extension-typography": "catalog:",
    "@tiptap/extension-underline": "catalog:",
    "@tiptap/react": "catalog:",
    "@tiptap/starter-kit": "catalog:",
    "@tiptap/suggestion": "catalog:",
    "@xterm/addon-fit": "catalog:",
    "@xterm/addon-image": "catalog:",
    "@xterm/addon-ligatures": "catalog:",
    "@xterm/addon-search": "catalog:",
    "@xterm/addon-serialize": "catalog:",
    "@xterm/addon-unicode11": "catalog:",
    "@xterm/addon-web-links": "catalog:",
    "@xterm/addon-webgl": "catalog:",
    "@xterm/xterm": "catalog:",
    "classnames": "catalog:",
    "immer": "catalog:",
    "jszip": "catalog:",
    "lucide-react": "catalog:",
    "markdown-it": "catalog:",
    "mediabunny": "^1.34.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@sdkwork/react-commons": "workspace:*",
    "@sdkwork/react-compression": "workspace:*",
    "@sdkwork/react-core": "workspace:*",
    "@sdkwork/react-fs": "workspace:*",
    "@sdkwork/react-i18n": "workspace:*",
    "@sdkwork/react-ide-config": "workspace:*",
    "@sdkwork/react-plugins": "workspace:*",
