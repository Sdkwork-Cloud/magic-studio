  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tauri-apps/cli": "catalog:",
    "@types/markdown-it": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "archiver": "catalog:",
    "autoprefixer": "catalog:",
    "concurrently": "catalog:",
    "cross-env": "catalog:",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "ignore": "catalog:",
    "png-to-ico": "catalog:",
    "postcss": "catalog:",
    "prettier": "^3.5.2",
    "sharp": "catalog:",
    "tailwindcss": "catalog:",
    "tailwindcss-animate": "catalog:",
    "vitest": "^3.2.4",
    "turbo": "^2.8.10",
    "typescript": "catalog:",
    "typescript-eslint": "^8.25.0",
    "vite": "catalog:"
  }
}
