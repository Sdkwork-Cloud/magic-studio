# Production Environment
# Live production configuration

# ============================================
# Application Environment
# ============================================
VITE_APP_ENV=production

# ============================================
# API Configuration
# ============================================
# Main API
VITE_API_BASE_URL=https://api.sdkwork.com
VITE_APP_API_BASE_URL=https://api.sdkwork.com
SDKWORK_API_BASE_URL=https://api.sdkwork.com
VITE_WS_URL=wss://api.sdkwork.com/ws

# IM (Instant Messaging) API
VITE_IM_API_BASE_URL=https://im-api.sdkwork.com

# ============================================
# Platform
# ============================================
VITE_PLATFORM=web
SDKWORK_PLATFORM=web

# ============================================
# Debug Settings
# ============================================
VITE_DEBUG=false
VITE_LOG_LEVEL=warn

# ============================================
# Feature Flags
# ============================================
VITE_FEATURE_ANALYTICS=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_WEBSOCKET=true
VITE_FEATURE_CACHE=true

# ============================================
# Authentication
# ============================================
VITE_ACCESS_TOKEN=
SDKWORK_ACCESS_TOKEN=

# ============================================
# Request Configuration
# ============================================
VITE_TIMEOUT=30000
SDKWORK_TIMEOUT=30000
